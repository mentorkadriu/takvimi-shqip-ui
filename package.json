{
  "name": "takvimi-shqip-ui",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "setup": "node scripts/fetchPrayerTimes.js",
